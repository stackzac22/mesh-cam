# Copy this file to secrets.yaml and fill in real values.
# secrets.yaml is gitignored — never commit real credentials.
# Reference these in Home Assistant config with: !secret <key>

# --- Home Assistant Mosquitto broker ---
mqtt_broker: 192.168.1.50
mqtt_user: mqtt_user
mqtt_pass: changeme

# --- Mesh / gateway identifiers ---
# Region your nodes run in (must match lora.region on every node), e.g. US, EU_868
mesh_region: US
# Primary channel name (appears in the MQTT topic), e.g. LongFast
mesh_channel: LongFast
# Gateway (Cardputer ADV) hex node id, including the leading !  -> from `meshtastic --info`
gateway_node_hex: "!7eef0000"
# Gateway decimal node id (the "num" field) -> used as the downlink "from"
gateway_node_decimal: 2130636288
